# Gemini AI (modules)
GEMINI_API_KEY=your_gemini_key_here

# Contact page — shown on website + optional email receiver
CONTACT_EMAIL=your.email@gmail.com

# MySQL (local) — use either DATABASE_URL or MYSQL_* variables
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/quick_study_db?charset=utf8mb4
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=quick_study_db

# Optional: receive feedback in your inbox (Gmail example)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
