# =============================================================================
# Copy to backend/.env and fill in your values.
# =============================================================================

# Gemini AI
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_API_KEYS=backup_key1,backup_key2
# GEMINI_MODEL=gemini-3.5-flash
QUESTIONBANK_DEMO_FALLBACK=false

# Admin login (set your own — not shown on the login page)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_NAME=Site Admin

CONTACT_EMAIL=your_contact_email@example.com

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=quick_study_db

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@gmail.com
SMTP_PASSWORD=your_gmail_app_password
